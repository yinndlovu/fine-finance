{
  "expo": {
    "name": "My Finances",
    "slug": "fine-finance",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/app-background.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/app-background.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0710"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0710",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.yinn.finefinance"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-splash-screen", "expo-status-bar"],
    "extra": {
      "eas": {
        "projectId": "ff87657e-ce68-47ab-bb57-b668aaef1de7"
      }
    }
  }
}
